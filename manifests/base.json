{
  "manifest_version": 3,
  "name": "StreamBridge",
  "description": "Find verified HLS and media URLs, play them in the browser, copy them, or share them.",
  "version": "0.1.0",
  "permissions": ["activeTab", "clipboardWrite", "scripting", "storage", "tabs", "webRequest"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "StreamBridge",
    "default_popup": "popup/index.html",
    "default_icon": "icons/streambridge.svg"
  },
  "icons": {
    "16": "icons/streambridge.svg",
    "32": "icons/streambridge.svg",
    "48": "icons/streambridge.svg",
    "128": "icons/streambridge.svg"
  },
  "web_accessible_resources": [{ "resources": ["icons/streambridge.svg"], "matches": ["<all_urls>"] }]
}
